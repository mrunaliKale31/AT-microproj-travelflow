rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    function isValidUserProfile(data) {
      return data.keys().hasAll(['name', 'email', 'createdAt']) 
        && data.keys().size() == 3
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 3 && data.email.size() <= 100
        && data.createdAt == request.time;
    }

    function isValidBooking(data, userId) {
      return data.keys().hasAll(['type', 'name', 'date', 'price', 'status', 'userId', 'createdAt'])
        && data.keys().size() == 7
        && data.type in ['Flight', 'Hotel']
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.date is string && data.date.size() > 0 && data.date.size() <= 100
        && data.price is number && data.price >= 0
        && data.status in ['Confirmed', 'Cancelled']
        && data.userId == userId
        && data.userId == request.auth.uid
        && data.createdAt == request.time;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name'])
      );

      match /bookings/{bookingId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidBooking(incoming(), userId);
        allow update: if isOwner(userId) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['status'])
        );
        allow delete: if false;
      }
    }
  }
}
